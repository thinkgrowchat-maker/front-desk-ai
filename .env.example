# Copy this file to ".env" and add ONE provider key to enable live AI answers.
# The app auto-detects which provider to use. With no key it runs in "demo mode"
# (retrieval + guardrail work; answers are templated — costs nothing).

# --- FREE, no credit card: Google Gemini ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- PAID: Anthropic Claude (takes priority if both keys are set) ---
# Get a key at https://console.anthropic.com  (requires prepaid credit)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
# GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_MODEL=claude-opus-4-8      # or claude-haiku-4-5
# PORT=8000
